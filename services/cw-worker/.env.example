# ============================================================
# CargoIQ CW Worker -- Environment Variables
# ============================================================
# Copy to services/cw-worker/.env (local dev) or set in your
# deployment platform (Railway worker service, etc.).
#
# This service runs TWO BullMQ workers from a single process
# (src/index.ts): "cw-executions" (CargoWise form automation,
# src/worker.ts) and "portal-jobs" (SARS/Transnet/shipping-line
# portal automation, src/portals/orchestrator.ts).

# ---- Supabase ----
# Service role key required -- this worker reads/writes
# portal_jobs, container_tracking, rla_statuses, etc. directly,
# bypassing RLS.
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# ---- Redis ----
# Must be the SAME Redis instance as apps/api (queue_service.py
# enqueues jobs here; this worker consumes them).
REDIS_URL=redis://localhost:6379

# ---- Encryption ----
# AES-256 key for decrypting CargoWise + portal credentials
# (src/utils/crypto.ts). MUST match ENCRYPTION_KEY in apps/api/.env
# -- credentials encrypted by the API must be decryptable by the
# worker.
ENCRYPTION_KEY=your-32-byte-hex-encryption-key

# ---- Browser automation (Playwright) ----
BROWSER_HEADLESS=true
BROWSER_TIMEOUT_MS=30000

# Where screenshots from portal jobs are written before being
# referenced in portal_jobs.screenshot. Mount this as a volume
# if you want screenshots to persist / be served.
SCREENSHOT_PATH=/tmp/cargoiq-screenshots

# ---- Logging ----
# debug | info | warn | error
LOG_LEVEL=info
