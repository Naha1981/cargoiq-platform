# ============================================================
# CargoIQ Web -- Environment Variables
# ============================================================
# Copy to apps/web/.env.local (local dev) or set in Vercel
# project settings for production.
#
# NEXT_PUBLIC_* vars are exposed to the browser -- never put
# secrets in them. Non-prefixed vars below are used only by the
# Next.js API route apps/web/app/api/email/send/route.ts, which
# runs server-side.

# ---- Supabase ----
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# ---- API ----
NEXT_PUBLIC_API_URL=http://localhost:8000
NEXT_PUBLIC_APP_URL=http://localhost:3000

# ---- Server-side: JWT verification for the email send route ----
# Generate with: openssl rand -hex 32 -- MUST match apps/api SECRET_KEY
SECRET_KEY=your-secret-key-min-32-chars-change-this

# ---- Email (unemail driver) ----
# Used by app/api/email/send/route.ts for all transactional emails:
# compliance alerts, RLA suspension notices, shipment-approved
# notices, savings certificate / success story sharing (future).
EMAIL_DRIVER=resend
EMAIL_FROM=alerts@cargoiq.co.za
EMAIL_FROM_NAME=CargoIQ
RESEND_API_KEY=re_your_resend_key

# AWS SES (alternative -- set EMAIL_DRIVER=ses)
AWS_REGION=af-south-1
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=

# SMTP (alternative -- set EMAIL_DRIVER=smtp, for on-premise clients)
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
