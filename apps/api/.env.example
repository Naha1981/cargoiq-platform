# ============================================================
# CargoIQ API -- Environment Variables
# ============================================================
# Copy to apps/api/.env (local dev) or set as env vars in your
# deployment platform (Railway, etc.) for production.

# ---- Supabase ----
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
SUPABASE_DB_URL=postgresql://postgres:password@db.your-project.supabase.co:5432/postgres

# ---- Anthropic (Claude API) ----
# Used by extraction_service.py (shipment extraction),
# carrier_audit_service.py (carrier invoice extraction), and
# compliance_service.py (Compliance Shield).
ANTHROPIC_API_KEY=sk-ant-your-key

# ---- Redis ----
# BullMQ queues: cw-executions, portal-jobs
REDIS_URL=redis://localhost:6379

# ---- App ----
APP_NAME=CargoIQ API
APP_VERSION=1.0.0
ENVIRONMENT=development
DEBUG=true

# Generate with: openssl rand -hex 32
# Also used by /internal/* endpoints: verify_internal() checks the
# x-internal-key header against the FIRST 16 CHARS of this value.
SECRET_KEY=your-secret-key-min-32-chars-change-this

ALLOWED_ORIGINS=http://localhost:3000,https://app.cargoiq.co.za

# ---- Encryption ----
# AES-256 key (encrypt_value/decrypt_value in core/security.py).
# Used for: CargoWise credentials, portal credentials (SARS/Transnet/
# shipping lines, see routers/portals.py).
# Generate with: openssl rand -hex 32
ENCRYPTION_KEY=your-32-byte-hex-encryption-key

# ---- Sentry (optional) ----
SENTRY_DSN=

# ---- File storage ----
MAX_UPLOAD_SIZE_MB=50
ALLOWED_MIME_TYPES=application/pdf,image/jpeg,image/png,image/tiff,application/msword,application/vnd.openxmlformats-officedocument.wordprocessingml.document

# ---- Email (unemail -- called via apps/web/app/api/email/send,
#      configured here for reference; the actual driver config lives
#      in apps/web/.env since that route runs in Next.js) ----
# See apps/web/.env.example for EMAIL_DRIVER / RESEND_API_KEY / etc.

# ---- WhatsApp (Evolution API) ----
# Used by notification_service.py (outbound alerts) and the
# /internal/webhooks/whatsapp-checkin/{org_id} webhook (inbound
# driver ARRIVED/DEPARTED check-ins).
EVOLUTION_API_URL=http://localhost:8080
EVOLUTION_API_KEY=cargoiq-evolution-key
