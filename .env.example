# ============================================================
# CargoIQ Platform — Root Environment Config
# ============================================================
# Copy to .env (same directory as docker-compose.yml) and fill in.
# NEVER commit .env to git. This file feeds docker-compose.yml and
# is also the reference for apps/api, apps/web, and services/cw-worker
# — each of those has its own .env.example with the subset it needs.

# ---- Supabase ----
# Get these from: Supabase Dashboard -> Project Settings -> API
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
# Get from: Project Settings -> Database -> Connection string (URI)
SUPABASE_DB_URL=postgresql://postgres:password@db.your-project.supabase.co:5432/postgres

# ---- Anthropic (Claude API) ----
# All AI extraction (shipments, carrier invoices) and the Compliance
# Shield use this key. Get from: console.anthropic.com
ANTHROPIC_API_KEY=sk-ant-your-key-here

# ---- Redis ----
# Used by BullMQ (cw-executions + portal-jobs queues)
REDIS_URL=redis://localhost:6379

# ---- App URLs ----
API_URL=http://localhost:8000
WEB_URL=http://localhost:3000
ENVIRONMENT=development

# ---- Secret Key ----
# Generate with: openssl rand -hex 32
# Used for JWT signing AND as the source for the internal n8n key
# (first 16 chars -- see CARGOIQ_INTERNAL_KEY below)
SECRET_KEY=your-secret-key-min-32-chars-change-this

# ---- Encryption Key ----
# AES-256 key for encrypting CargoWise + portal credentials at rest.
# Generate with: openssl rand -hex 32
ENCRYPTION_KEY=your-32-byte-hex-key-here

# ---- Email (unemail driver -- used for compliance alerts, RLA
#      suspension notices, savings certificate emails, etc.) ----
EMAIL_DRIVER=resend
EMAIL_FROM=alerts@cargoiq.co.za
EMAIL_FROM_NAME=CargoIQ
RESEND_API_KEY=re_your_resend_key

# AWS SES (alternative driver -- set EMAIL_DRIVER=ses to use)
AWS_REGION=af-south-1
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=

# SMTP (alternative driver -- set EMAIL_DRIVER=smtp to use, for
# on-premise / client-managed mail servers)
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=

# ---- WhatsApp (Evolution API) ----
# Self-hosted via docker-compose. Used for:
#   - outbound compliance/RLA/demurrage alerts (notification_service.py)
#   - inbound driver ARRIVED/DEPARTED check-ins (driver_checkin_service.py)
# AUTHENTICATION_API_KEY in docker-compose must match EVOLUTION_API_KEY.
EVOLUTION_API_URL=http://localhost:8080
EVOLUTION_API_KEY=cargoiq-evolution-key

# ---- n8n (cron workflows: 01_daily_rla_sentinel, 02_container_tracker,
#      03_notification_processor) ----
# These are set INSIDE the n8n container/UI, not read by apps/api
# directly -- listed here so they're not lost. Both must point at
# your deployed API.
#
# CARGOIQ_INTERNAL_KEY   = first 16 characters of SECRET_KEY above
#                          (sent as the x-internal-key header to
#                          /internal/notifications/process)
# CARGOIQ_INTERNAL_TOKEN = a long-lived JWT for an admin user, used
#                          as a Bearer token for /portals/rla/bulk-check
#                          and /portals/containers/bulk-track (these
#                          endpoints require get_current_user_with_org)
CARGOIQ_INTERNAL_KEY=
CARGOIQ_INTERNAL_TOKEN=

# ---- Gmail OAuth (for client email inbox connections -- Settings ->
#      Email Connection) ----
GMAIL_CLIENT_ID=
GMAIL_CLIENT_SECRET=
GMAIL_REDIRECT_URI=http://localhost:8000/api/v1/integrations/gmail/callback

# ---- Browser automation (cw-worker: CargoWise forms + portal adapters) ----
BROWSER_HEADLESS=true
BROWSER_TIMEOUT_MS=30000
SCREENSHOT_PATH=/tmp/cargoiq-screenshots
LOG_LEVEL=info
