# ============================================
# CargoIQ Platform — Root Environment Config
# ============================================
# Copy this to .env and fill in your values.
# NEVER commit .env to git.

# ---- Supabase ----
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
SUPABASE_DB_URL=postgresql://postgres:password@db.your-project.supabase.co:5432/postgres

# ---- Anthropic (Claude API) ----
ANTHROPIC_API_KEY=sk-ant-your-key-here

# ---- Redis ----
REDIS_URL=redis://localhost:6379

# ---- App ----
API_URL=http://localhost:8000
WEB_URL=http://localhost:3000
ENVIRONMENT=development

# ---- Encryption (generate with: openssl rand -hex 32) ----
ENCRYPTION_KEY=your-32-byte-hex-key-here

# ---- Email (for future Gmail/Outlook connectors) ----
GMAIL_CLIENT_ID=
GMAIL_CLIENT_SECRET=
GMAIL_REDIRECT_URI=http://localhost:8000/api/v1/integrations/gmail/callback

# ---- Email (unemail driver config) ----
EMAIL_DRIVER=resend
EMAIL_FROM=alerts@cargoiq.co.za
EMAIL_FROM_NAME=CargoIQ
RESEND_API_KEY=re_your_resend_key

# AWS SES (production)
AWS_REGION=af-south-1
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=

# SMTP (on-premise clients)
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=

# ---- WhatsApp (Evolution API) ----
EVOLUTION_API_URL=http://localhost:8080
EVOLUTION_API_KEY=cargoiq-evolution-key
